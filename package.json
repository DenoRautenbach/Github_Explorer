{
  "name": "github-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import ./vite-polyfill.js ./node_modules/vite/bin/vite.js",
    "build": "vue-tsc -b && node --import ./vite-polyfill.js ./node_modules/vite/bin/vite.js build",
    "preview": "node --import ./vite-polyfill.js ./node_modules/vite/bin/vite.js preview",
    "test:unit": "vitest",
    "test": "npm run test:unit"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.4"
  }
}